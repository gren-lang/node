module Main exposing (main)

import Node exposing (Environment, Program)
import Init
import Bytes exposing (Bytes)
import Dict exposing (Dict)
import Stream
import Stream.Log
import WebSocketServer
import WebSocketServer.Connection as WsConn
import Task exposing (Task)


main : Program Model Msg
main =
    Node.defineProgram
        { init = init
        , update = update
        , subscriptions = \_ -> Sub.none
        }


type alias Model =
    { stdout : Stream.Writable Bytes
    , stderr : Stream.Writable Bytes
    , server : Maybe WebSocketServer.Server
    , connections : Dict Int WebSocketServer.Connection
    }


type Msg
    = ServerCreated
        (Result
            WebSocketServer.ServerError
            { server : WebSocketServer.Server
            , connections : Stream.Readable WebSocketServer.Connection
            }
        )
    | ConnectionAccepted
        { connections : Stream.Readable WebSocketServer.Connection
        , result : Result Stream.Error WebSocketServer.Connection
        }
    | MessageReceived
        { connection : WebSocketServer.Connection
        , result : Result Stream.Error WebSocketServer.Message
        }
    | SendResult (Result WsConn.Error {})
    | ServerStopped (Result WebSocketServer.ServerError {})


init : Environment -> Init.Task { model : Model, command : Cmd Msg }
init env =
    Init.await WebSocketServer.initialize <| \wsPermission ->
        Node.startProgram
            { model =
                { stdout = env.stdout
                , stderr = env.stderr
                , server = Nothing
                , connections = Dict.empty
                }
            , command =
                WebSocketServer.startServer wsPermission { host = "127.0.0.1", port_ = 8085 }
                    |> Task.attempt ServerCreated
            }


readNextConnection : Stream.Readable WebSocketServer.Connection -> Cmd Msg
readNextConnection connections =
    Stream.read connections
        |> Task.attempt
            (\result -> ConnectionAccepted { connections = connections, result = result })


readNextMessage : WebSocketServer.Connection -> Cmd Msg
readNextMessage conn =
    Stream.read conn.incoming
        |> Task.attempt
            (\result -> MessageReceived { connection = conn, result = result })


update : Msg -> Model -> { model : Model, command : Cmd Msg }
update msg model =
    when msg is
        ServerCreated (Ok { server, connections }) ->
            { model = { model | server = Just server }
            , command =
                Cmd.batch
                    [ Stream.Log.line model.stdout "WebSocket server started on port 8085"
                        |> Task.execute
                    , readNextConnection connections
                    ]
            }

        ServerCreated (Err (WebSocketServer.ServerError { code, message })) ->
            { model = model
            , command =
                Stream.Log.line model.stderr ("Server error: " ++ code ++ " " ++ message)
                    |> Task.execute
            }

        ConnectionAccepted { connections, result = Ok conn } ->
            let
                connId =
                    conn.id
            in
            { model =
                { model | connections = Dict.set connId conn model.connections }
            , command =
                Cmd.batch
                    [ WsConn.send conn "welcome"
                        |> Task.attempt SendResult
                    , readNextMessage conn
                    , readNextConnection connections
                    ]
            }

        ConnectionAccepted { result = Err _ } ->
            { model = model, command = Cmd.none }

        MessageReceived { connection = conn, result = Ok (WebSocketServer.TextMessage text) } ->
            if text == "please-close" then
                { model = model
                , command =
                    Cmd.batch
                        [ WsConn.close conn 1000 "server-initiated-close"
                            |> Task.attempt SendResult
                        , readNextMessage conn
                        ]
                }
            else if text == "please-stop-server" then
                when model.server is
                    Just server ->
                        { model = model
                        , command =
                            WebSocketServer.stopServer server
                                |> Task.attempt ServerStopped
                        }

                    Nothing ->
                        { model = model, command = readNextMessage conn }
            else
                { model = model
                , command =
                    Cmd.batch
                        [ WsConn.send conn ("echo:" ++ text)
                            |> Task.attempt SendResult
                        , readNextMessage conn
                        ]
                }

        MessageReceived { connection = conn, result = Ok (WebSocketServer.BinaryMessage bytes) } ->
            { model = model
            , command =
                Cmd.batch
                    [ WsConn.sendBytes conn bytes
                        |> Task.attempt SendResult
                    , readNextMessage conn
                    ]
            }

        MessageReceived { connection = conn, result = Err _ } ->
            let
                connId =
                    conn.id
            in
            { model =
                { model | connections = Dict.remove connId model.connections }
            , command = Cmd.none
            }

        SendResult _ ->
            { model = model, command = Cmd.none }

        ServerStopped result ->
            when result is
                Ok _ ->
                    { model = { model | server = Nothing }
                    , command =
                        Stream.Log.line model.stdout "WebSocket server stopped"
                            |> Task.execute
                    }

                Err (WebSocketServer.ServerError { code, message }) ->
                    { model = model
                    , command =
                        Stream.Log.line model.stderr ("Stop error: " ++ code ++ " " ++ message)
                            |> Task.execute
                    }
