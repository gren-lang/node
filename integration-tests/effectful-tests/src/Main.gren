module Main exposing (main)

import Expect
import Node
import Test.Runner.Effectful as Effectful exposing (test, await, concat)
import Sqlite
import Json.Encode as Encode
import Json.Decode as Decode exposing (Decoder)
import Task exposing (Task)


main : Effectful.Program a
main = 
    Node.defineSimpleProgram <| \env ->
        Effectful.run env tests


tests : Effectful.Test
tests =
    Effectful.concat
        [ await "Creating a database" createTestDb <| \db ->
            test "Works" <| \_ ->
                Expect.pass
        , await "Open db for single insert" createTestDb <| \db ->
            await "Insert robin" (insertPerson robin db) <| \_ ->
            await "Read robin from db" (getPersonByName robin.name db) <| \p ->
                concat
                    [ test "Name is robin.name" <| \_ ->
                        Expect.equal robin.name p.name
                    , test "Role is robin.role" <| \_ ->
                        Expect.equal robin.role p.role
                    ]
        , await "Open db for multiple inserts" createTestDb <| \db ->
            await "Insert all people" (insertPeople people db) <| \summary ->
            await "Read all people from db" (getAllPeople db) <| \fromDB ->
                concat
                    [ test "summary.changes is 1 (only reports from last execution)" <| \_ ->
                        Expect.equal 1 summary.changes
                    , test "summary.lastInsertedRowid is > 0" <| \_ ->
                        Expect.greaterThan 0 summary.lastInsertRowid
                    , test "Users are what we'd expect" <| \_ ->
                        Expect.equalArrays
                            (Array.sortBy .name people)
                            (Array.sortBy .name fromDB)
                    ]
        ]


-- Helpers


type alias Person =
    { name : String
    , role : String
    }

robin : Person
robin =
    { name = "Robin"
    , role = "Creator"
    }


justin : Person
justin =
    { name = "Justin"
    , role = "Core developer"
    }


people : Array Person
people = [ robin, justin ]


createTestDb : Task Sqlite.Error Sqlite.Database
createTestDb =
    Sqlite.openInMemory Sqlite.defaultOptions
        |> Task.andThen
            (Sqlite.executeScript
                """
                CREATE TABLE people (
                    id INTEGER PRIMARY KEY,
                    name TEXT NOT NULL,
                    role TEXT NOT NULL
                ) STRICT;
                """
            )


personEncoder : Person -> Encode.Value
personEncoder p =
    Encode.object
        [ { key = "name", value = Encode.string p.name }
        , { key = "role", value = Encode.string p.role }
        ]


personDecoder : Decoder Person
personDecoder =
    Decode.map2 (\name role -> { name = name, role = role })
        (Decode.field "name" Decode.string)
        (Decode.field "role" Decode.string)


insertPerson : Person -> Sqlite.Database -> Task Sqlite.Error Sqlite.Database
insertPerson person db =
    Sqlite.execute
        { statement = "INSERT INTO people (name, role) VALUES (:name, :role)"
        , encoder = personEncoder
        }
        person
        db
        |> Task.map (\_ -> db)


getPersonByName : String -> Sqlite.Database -> Task Sqlite.Error Person
getPersonByName name db =
    Sqlite.getOne
        { query = "SELECT * FROM people WHERE name = :name"
        , parameters = Encode.object [ { key = "name", value = Encode.string name } ]
        , rowDecoder = personDecoder
        }
        db


insertPeople : Array Person -> Sqlite.Database -> Task Sqlite.Error Sqlite.ExecutionSummary
insertPeople persons db =
    Sqlite.executeMany
        { statement = "INSERT INTO people (name, role) VALUES (:name, :role)"
        , encoder = personEncoder
        }
        persons
        db


getAllPeople : Sqlite.Database -> Task Sqlite.Error (Array Person)
getAllPeople db =
    Sqlite.getAll
        { query = "SELECT * FROM people"
        , parameters = Encode.object []
        , rowDecoder = personDecoder
        }
        db
